{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user health profile and cycle settings",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's display name" },
        "averageCycleLength": { "type": "number", "description": "Average length of the menstrual cycle in days" },
        "averagePeriodLength": { "type": "number", "description": "Average length of the period in days" },
        "conditions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of health conditions (PCOS, Endometriosis, etc.)"
        },
        "lastPeriodDate": { "type": "string", "format": "date-time", "description": "ISO string of the last period start date" }
      },
      "required": ["name", "averageCycleLength", "averagePeriodLength", "conditions", "lastPeriodDate"]
    },
    "DailyLog": {
      "title": "Daily Log",
      "description": "User's daily health and symptom log",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "ISO date string (YYYY-MM-DD)" },
        "flow": { "type": "string", "enum": ["None", "Light", "Medium", "Heavy"], "description": "Menstrual flow intensity" },
        "symptoms": { "type": "array", "items": { "type": "string" }, "description": "List of symptoms experienced" },
        "mood": { "type": "string", "description": "User's mood for the day" },
        "energy": { "type": "number", "description": "Energy level from 1 to 10" }
      },
      "required": ["date", "flow", "symptoms", "mood", "energy"]
    },
    "Medication": {
      "title": "Medication",
      "description": "User's medication or supplement",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the medication" },
        "dosage": { "type": "string", "description": "Dosage amount" },
        "frequency": { "type": "string", "description": "How often the medication is taken" },
        "reminderTime": { "type": "string", "description": "Optional reminder time (HH:mm)" },
        "active": { "type": "boolean", "description": "Whether the medication is currently active" }
      },
      "required": ["name", "dosage", "frequency", "active"]
    },
    "ForumPost": {
      "title": "Forum Post",
      "description": "An anonymous community post",
      "type": "object",
      "properties": {
        "authorName": { "type": "string", "description": "Anonymous display name" },
        "content": { "type": "string", "description": "Content of the post" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time the post was created" },
        "likes": { "type": "number", "description": "Number of likes" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags associated with the post" }
      },
      "required": ["authorName", "content", "timestamp", "likes", "tags"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "DailyLog",
      "description": "Daily logs for a specific user"
    },
    "/users/{userId}/medications/{medId}": {
      "schema": "Medication",
      "description": "Medications for a specific user"
    },
    "/forum_posts/{postId}": {
      "schema": "ForumPost",
      "description": "Global forum posts"
    }
  }
}
